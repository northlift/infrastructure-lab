#!/bin/sh
# Pre-push hook: blocks harness files from being pushed to GitHub.
#
# Harness files (.pi/, .ai/, AGENTS.md, PLAYBOOK.md) are internal to the
# self-hosted Forgejo. They must NOT be pushed to public GitHub repos.
#
# This hook checks the remote URL and the files in the push range.
# Pushes to non-GitHub remotes (e.g. forgejo) are always allowed.

set -e

REMOTE_NAME="$1"
REMOTE_URL="$2"

# Only check GitHub remotes
case "$REMOTE_URL" in
  *github.com*)
    ;;
  *)
    # Not a GitHub remote — allow
    exit 0
    ;;
esac

# Read stdin for refs being pushed
HARNESS_PATTERNS="^\.pi/|^\.ai/|^AGENTS\.md$|^PLAYBOOK\.md$"

while read LOCAL_REF LOCAL_OID REMOTE_REF REMOTE_OID; do
  # Skip deleted branches
  if [ "$LOCAL_OID" = "0000000000000000000000000000000000000000" ]; then
    continue
  fi

  # Get the list of files changed in this push
  if [ "$REMOTE_OID" = "0000000000000000000000000000000000000000" ]; then
    # New branch — compare against HEAD
    RANGE="origin/$REMOTE_REF..$LOCAL_OID"
  else
    RANGE="$REMOTE_OID..$LOCAL_OID"
  fi

  HARNESS_FILES=$(git diff --name-only "$RANGE" 2>/dev/null | grep -E "$HARNESS_PATTERNS" || true)

  if [ -n "$HARNESS_FILES" ]; then
    echo ""
    echo "============================================"
    echo " BLOCKED: Harness files detected in push to GitHub"
    echo " Remote: $REMOTE_URL"
    echo " Ref:    $REMOTE_REF"
    echo ""
    echo " These files must not be pushed to GitHub:"
    echo "$HARNESS_FILES" | sed 's/^/   /'
    echo ""
    echo " Push to forgejo instead:"
    echo "   git push origin $REMOTE_REF"
    echo "============================================"
    exit 1
  fi
done

exit 0